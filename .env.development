VITE_API_BASE_URL=
VITE_DATAHUB_BASE_URL=http://localhost:3500
# Publikasi: pakai API publik (atau samakan dengan instance lokal jika ada)
VITE_PUBLICATION_API_BASE_URL=https://datahub-api.kasulampua.id

# CKAN: tetap pakai path relatif supaya permintaan ke origin Vite (localhost), lalu di-proxy ke CKAN — tidak kena CORS.
# Jangan set VITE_CKAN_BASE_URL ke https://data.kasulampua.id/... saat pnpm dev.
VITE_CKAN_BASE_URL=/ckan-api
VITE_CKAN_FILE_BASE_URL=/ckan-file

# Opsional: target proxy Vite ke CKAN (hanya vite.config, tidak ke bundle). Contoh lokal: http://127.0.0.1:5000
# DEV_CKAN_PROXY_TARGET=https://data.kasulampua.id
VITE_MATOMO_URL=https://itik.kasulampua.id
